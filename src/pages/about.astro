---
import Base from '../layouts/Base.astro';
---

<Base title="About Us | Mortgage Calculator" description="Learn more about Mortgage Calculator — our mission to build free, high-performance financial tools for US homebuyers." page="about">

<div class="hero" style="max-width: 800px; padding-bottom: 5rem;">
  <div class="hero-chip">
    <div class="hero-chip-dot"></div>
    <span>Our Mission</span>
  </div>
  <h1>About <strong>Mortgage Calculator</strong></h1>
  <p class="hero-sub" style="max-width: 600px; margin-bottom: 2rem;">We build lightweight, search-optimized, and mathematical tools to help you make informed financial decisions when buying or refinancing a home.</p>
</div>

<section style="padding: 0 0 5rem;">
  <div class="container" style="max-width: 800px; background: var(--surf); border: 1px solid var(--bd); border-radius: var(--rl); padding: 3rem 2.5rem; box-shadow: var(--sh);">
    <h2 style="font-family: var(--font-display); font-size: 24px; font-weight: 700; margin-bottom: 1.25rem;">Why We Built This</h2>
    <p style="font-size: 15px; color: var(--ink2); line-height: 1.75; margin-bottom: 1.5rem;">Finding an honest, fast, and ad-light mortgage calculator shouldn't require dodging popups, newsletters, or predatory lender referrals. Mortgage Calculator was created to provide homebuyers with instant, premium-grade calculation engines built on web standards.</p>
    
    <h2 style="font-family: var(--font-display); font-size: 20px; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem;">Our Core Principles</h2>
    <ul style="font-size: 15px; color: var(--ink2); line-height: 1.75; padding-left: 20px; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 8px;">
      <li><strong>Accuracy First:</strong> Our algorithms use standard amortization formulas and support complex edge-cases like dynamic Private Mortgage Insurance (PMI) triggers.</li>
      <li><strong>No Data Harvesting:</strong> We don't save your inputs, ask for your email, or sell your financial data to third-party lenders. Your math is private to you.</li>
      <li><strong>Extreme Performance:</strong> Built using Astro and vanilla JavaScript, our pages load instantly and run calculations entirely on your local device.</li>
    </ul>

    <h2 style="font-family: var(--font-display); font-size: 20px; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem;">Brought to you by Social Ninja's</h2>
    <p style="font-size: 15px; color: var(--ink2); line-height: 1.75;">This tool is designed, developed, and maintained by <strong>Social Ninja's AI Agency</strong>. We create high-performing automation systems, custom marketing funnels, and free interactive tools to help businesses and consumers scale efficiently.</p>
    <p style="font-size: 15px; margin-top: 1.25rem;"><a href="https://socialninjas.in" target="_blank" style="color: var(--blue); font-weight: 700; text-decoration: none;">Learn more about Social Ninja's →</a></p>
  </div>
</section>

</Base>
