---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);
---

<Base title="Mortgage Refinance Calculator 2025 | MortgageCalc.us" description="Calculate your monthly savings and break-even point from refinancing your home mortgage. View detailed interest breakdowns." page="refi">

<div class="hero">
  <div class="hero-chip">
    <div class="hero-chip-dot"></div>
    <span>Refinance Savings Analysis</span>
  </div>
  <h1>Mortgage <strong>Refinance Calculator</strong></h1>
  <p class="hero-sub">Compare your current home loan details with new interest rates to see if refinancing will save you money.</p>
  
  <div class="hero-stats">
    <div class="hstat">
      <div class="hstat-n" id="stat-monthly-savings">$298</div>
      <div class="hstat-l">Est. Monthly Savings</div>
    </div>
    <div class="hstat">
      <div class="hstat-n" id="stat-breakeven">20 Months</div>
      <div class="hstat-l">Break-Even Point</div>
    </div>
    <div class="hstat">
      <div class="hstat-n" id="stat-lifetime-savings">$107,280</div>
      <div class="hstat-l">Total Interest Saved</div>
    </div>
  </div>
</div>

<div class="tool-grid">
  <!-- INPUTS CARD -->
  <div class="card">
    <div class="card-head">
      <div class="ch-icon" style="background:var(--bluel);color:var(--blue);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 7h6M9 12h6M9 17h6"/></svg>
      </div>
      <div>
        <div class="ch-title">Current & New Loan</div>
        <div class="ch-sub">Enter your loan details and refinance offer</div>
      </div>
    </div>

    <!-- Current Loan Balance -->
    <div class="field">
      <label class="lbl" for="current-loan">Remaining Loan Balance</label>
      <div class="pfx">
        <span>$</span>
        <input type="number" id="current-loan" value="300000" min="5000" step="5000" />
      </div>
    </div>

    <!-- Current Payment & Current Rate -->
    <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:12px;margin-bottom:14px;">
      <div>
        <label class="lbl" for="current-payment">Current Monthly Payment (P&I)</label>
        <div class="pfx">
          <span>$</span>
          <input type="number" id="current-payment" value="2097.64" min="100" step="10" />
        </div>
      </div>
      <div>
        <label class="lbl" for="current-rate">Current Rate</label>
        <div class="sfx">
          <span>%</span>
          <input type="number" id="current-rate" value="7.5" min="0.1" max="25" step="0.01" />
        </div>
      </div>
    </div>

    <!-- New Rate & New Term -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
      <div>
        <label class="lbl" for="new-rate">New Interest Rate</label>
        <div class="sfx">
          <span>%</span>
          <input type="number" id="new-rate" value="6.0" min="0.1" max="25" step="0.01" />
        </div>
      </div>
      <div>
        <label class="lbl" for="new-term">New Loan Term</label>
        <select id="new-term">
          <option value="30" selected>30 Years (Fixed)</option>
          <option value="20">20 Years (Fixed)</option>
          <option value="15">15 Years (Fixed)</option>
          <option value="10">10 Years (Fixed)</option>
        </select>
      </div>
    </div>

    <!-- Refinancing Closing Costs -->
    <div class="field">
      <label class="lbl" for="refi-costs">Refinance Closing Costs</label>
      <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:12px;">
        <div class="pfx">
          <span>$</span>
          <input type="number" id="refi-costs" value="6000" min="0" step="100" />
        </div>
        <div class="sfx">
          <span>%</span>
          <input type="number" id="refi-costs-pct" value="2.0" min="0" max="10" step="0.1" />
        </div>
      </div>
      <span class="hint">Includes lender fees, title search, appraisal, and closing costs (typically 2% to 4% of loan amount).</span>
    </div>
  </div>

  <!-- RESULTS CARD -->
  <div class="card">
    <div class="card-head">
      <div class="ch-icon" style="background:var(--greenl);color:var(--green);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <div>
        <div class="ch-title">Refinance Analysis</div>
        <div class="ch-sub">Calculation of your potential savings</div>
      </div>
    </div>

    <div class="result-hero" style="background:linear-gradient(135deg, var(--blue), var(--bluem));">
      <div class="result-label">New Estimated Monthly Payment</div>
      <div class="result-value" id="result-new-payment">$1,798</div>
      <div class="result-sub" id="result-summary">Save $298.92 per month on P&I</div>
    </div>

    <!-- Detailed Expense Breakdown Table -->
    <div class="breakdown">
      <div class="brow">
        <div class="brow-lbl">Current Monthly Payment</div>
        <div class="brow-val" id="breakdown-old-payment" style="color:var(--red);">$2,097.64</div>
      </div>
      <div class="brow">
        <div class="brow-lbl">New Monthly Payment</div>
        <div class="brow-val" id="breakdown-new-payment" style="color:var(--green);">$1,798.65</div>
      </div>
      <div class="brow" style="border-top:1.5px solid var(--bd2);">
        <div class="brow-lbl" style="font-weight:600;">Monthly P&I Savings</div>
        <div class="brow-val pos" id="breakdown-monthly-savings" style="font-weight:600;">$298.99</div>
      </div>
      <div class="brow">
        <div class="brow-lbl">Refinancing Closing Costs</div>
        <div class="brow-val" id="breakdown-costs" style="color:var(--ink3);">$6,000.00</div>
      </div>
      <div class="brow" style="background:var(--bluel);">
        <div class="brow-lbl" style="font-weight:600;">Break-Even Period</div>
        <div class="brow-val" id="breakdown-breakeven" style="font-weight:700;color:var(--blue);">20 Months</div>
      </div>
      <div class="brow total" style="background:var(--greenl);">
        <div class="brow-lbl" style="color:var(--green);">Lifetime Interest Savings</div>
        <div class="brow-val pos" id="breakdown-lifetime-savings" style="font-size:16px;">$107,636.40</div>
      </div>
    </div>
  </div>
</div>

<!-- DETAILED ANALYSIS STEPS -->
<section style="padding:1rem 0 5rem;">
  <div class="container">
    <div class="sec-label">Guides</div>
    <h2 class="sec-title">Is Refinancing Worth It?</h2>
    
    <div class="steps">
      <div class="step">
        <div class="step-n">1</div>
        <h3>Check the Interest Rate</h3>
        <p>Refinancing is typically beneficial if you can lower your interest rate by at least 0.5% to 1.0%. This directly reduces your monthly costs and long-term interest.</p>
      </div>

      <div class="step">
        <div class="step-n">2</div>
        <h3>Calculate the Break-Even Point</h3>
        <p>Divide your closing costs by your monthly savings. If closing costs are $6,000 and savings are $300/mo, your break-even point is 20 months. If you plan to stay in the home longer than this, it makes sense!</p>
      </div>

      <div class="step">
        <div class="step-n">3</div>
        <h3>Consider Closing Costs</h3>
        <p>Refinancing is not free. You must pay 2% to 4% of the loan balance in administrative fees, titles, and appraisal costs, which can either be paid upfront or rolled into the new loan.</p>
      </div>

      <div class="step">
        <div class="step-n">4</div>
        <h3>Resetting the Clock</h3>
        <p>Be aware that extending your loan term (e.g. moving from a remaining 20 years to a new 30-year term) can sometimes increase your lifetime interest paid, even if the rate is lower.</p>
      </div>
    </div>
  </div>
</section>

<!-- CALCULATION ENGINE SCRIPT -->
<script is:inline>
  const currentLoanInput = document.getElementById('current-loan');
  const currentPaymentInput = document.getElementById('current-payment');
  const currentRateInput = document.getElementById('current-rate');
  const newRateInput = document.getElementById('new-rate');
  const newTermSelect = document.getElementById('new-term');
  const refiCostsInput = document.getElementById('refi-costs');
  const refiCostsPctInput = document.getElementById('refi-costs-pct');

  function calculate() {
    const loanBalance = parseFloat(currentLoanInput.value) || 0;
    const oldPayment = parseFloat(currentPaymentInput.value) || 0;
    const oldRate = parseFloat(currentRateInput.value) || 0;
    const newRate = parseFloat(newRateInput.value) || 0;
    const newTermYears = parseFloat(newTermSelect.value) || 30;
    const closingCosts = parseFloat(refiCostsInput.value) || 0;

    // Monthly Principal & Interest (P&I) for New Loan
    const monthlyRate = newRate / 100 / 12;
    const totalPayments = newTermYears * 12;
    let newPayment = 0;
    
    if (loanBalance > 0) {
      if (monthlyRate > 0) {
        newPayment = loanBalance * (monthlyRate * Math.pow(1 + monthlyRate, totalPayments)) / (Math.pow(1 + monthlyRate, totalPayments) - 1);
      } else {
        newPayment = loanBalance / totalPayments;
      }
    }

    const monthlySavings = Math.max(0, oldPayment - newPayment);
    const breakEvenMonths = monthlySavings > 0 ? closingCosts / monthlySavings : 0;
    const lifetimeSavings = monthlySavings * totalPayments;

    // Update stats
    document.getElementById('stat-monthly-savings').textContent = '$' + Math.round(monthlySavings).toLocaleString();
    document.getElementById('stat-breakeven').textContent = breakEvenMonths > 0 ? `${Math.round(breakEvenMonths)} Months` : 'N/A';
    document.getElementById('stat-lifetime-savings').textContent = '$' + Math.round(lifetimeSavings).toLocaleString();

    // Update Result card
    document.getElementById('result-new-payment').textContent = '$' + Math.round(newPayment).toLocaleString();
    document.getElementById('result-summary').textContent = monthlySavings > 0 
      ? `Save $${Math.round(monthlySavings).toLocaleString()} per month on P&I` 
      : 'No monthly savings with these terms.';

    document.getElementById('breakdown-old-payment').textContent = '$' + oldPayment.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById('breakdown-new-payment').textContent = '$' + newPayment.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById('breakdown-monthly-savings').textContent = '$' + monthlySavings.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById('breakdown-costs').textContent = '$' + closingCosts.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById('breakdown-breakeven').textContent = breakEvenMonths > 0 ? `${Math.round(breakEvenMonths)} Months` : 'Never';
    document.getElementById('breakdown-lifetime-savings').textContent = '$' + lifetimeSavings.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  // Sync closing costs percentages
  currentLoanInput.addEventListener('input', () => {
    const loan = parseFloat(currentLoanInput.value) || 0;
    const pct = parseFloat(refiCostsPctInput.value) || 0;
    refiCostsInput.value = Math.round(loan * (pct / 100));

    // Auto-fill a recommended current payment based on loan balance and current rate
    const oldRate = parseFloat(currentRateInput.value) || 0;
    const monthlyRate = oldRate / 100 / 12;
    const totalPayments = 360; // Assume standard 30-year start
    if (loan > 0 && oldRate > 0) {
      const pi = loan * (monthlyRate * Math.pow(1 + monthlyRate, totalPayments)) / (Math.pow(1 + monthlyRate, totalPayments) - 1);
      currentPaymentInput.value = pi.toFixed(2);
    }

    calculate();
  });

  currentRateInput.addEventListener('input', () => {
    const loan = parseFloat(currentLoanInput.value) || 0;
    const oldRate = parseFloat(currentRateInput.value) || 0;
    const monthlyRate = oldRate / 100 / 12;
    const totalPayments = 360;
    if (loan > 0 && oldRate > 0) {
      const pi = loan * (monthlyRate * Math.pow(1 + monthlyRate, totalPayments)) / (Math.pow(1 + monthlyRate, totalPayments) - 1);
      currentPaymentInput.value = pi.toFixed(2);
    }
    calculate();
  });

  refiCostsInput.addEventListener('input', () => {
    const loan = parseFloat(currentLoanInput.value) || 0;
    const costs = parseFloat(refiCostsInput.value) || 0;
    if (loan > 0) {
      refiCostsPctInput.value = ((costs / loan) * 100).toFixed(1);
    }
    calculate();
  });

  refiCostsPctInput.addEventListener('input', () => {
    const loan = parseFloat(currentLoanInput.value) || 0;
    const pct = parseFloat(refiCostsPctInput.value) || 0;
    refiCostsInput.value = Math.round(loan * (pct / 100));
    calculate();
  });

  currentPaymentInput.addEventListener('input', calculate);
  newRateInput.addEventListener('input', calculate);
  newTermSelect.addEventListener('change', calculate);

  // Run initial calculation
  calculate();
</script>

</Base>
