---
import '../styles/global.css';
interface Props { title: string; description: string; canonical?: string; page?: string; }
const { title, description, canonical, page = '' } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en-us" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://mortgage.socialninjas.in/og-image.png" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Mortgage Calculator" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="geo.region" content="US" />
  <meta name="language" content="English" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#1F4B99" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Mortgage Calculator",
    "url": "https://mortgage.socialninjas.in",
    "description": "Free US mortgage calculator — payment calculator, affordability, refinance, and 15 expert mortgage guides."
  }
  </script>
</head>
<body>
<nav>
  <a class="logo" href="/">
    <div class="logo-mark">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
    </div>
    <span class="logo-name">Mortgage<em>Calc</em></span>
  </a>
  <div class="nav-right" style="display: flex; align-items: center; gap: 10px;">
    <div class="nav-links">
      <a href="/" class={page==='home'?'active':''}>Calculator</a>
      <a href="/affordability" class={page==='afford'?'active':''}>Affordability</a>
      <a href="/refinance" class={page==='refi'?'active':''}>Refinance</a>
      <a href="/blog" class={page==='blog'?'active':''}>Blog</a>
    </div>
    <span class="nav-pill">🇺🇸 Free Tool</span>
    
    <!-- Mobile Hamburger Toggle -->
    <button class="mobile-menu-btn" id="menuBtn" aria-label="Toggle Menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" class="line1"></line>
        <line x1="3" y1="12" x2="21" y2="12" class="line2"></line>
        <line x1="3" y1="18" x2="21" y2="18" class="line3"></line>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Sliding Drawer -->
<div class="mobile-drawer" id="mobileDrawer">
  <div class="drawer-links">
    <a href="/" class={page==='home'?'active':''}>Mortgage Calculator</a>
    <a href="/affordability" class={page==='afford'?'active':''}>Affordability Calculator</a>
    <a href="/refinance" class={page==='refi'?'active':''}>Refinance Calculator</a>
    <a href="/blog" class={page==='blog'?'active':''}>Expert Mortgage Guides</a>
  </div>
  
  <div class="drawer-promo-card">
    <div class="promo-title">Social Ninja's AI Agency</div>
    <div class="promo-text">We build automated client acquisition systems, custom chatbots, and manage high-converting Meta/Google ad campaigns.</div>
    <a href="https://socialninjas.in/contact" target="_blank" class="promo-btn">Get Free Growth Audit →</a>
  </div>
</div>

<script is:inline>
  const btn = document.getElementById('menuBtn');
  const drawer = document.getElementById('mobileDrawer');
  if (btn && drawer) {
    btn.addEventListener('click', () => {
      drawer.classList.toggle('open');
      btn.classList.toggle('active');
      document.body.style.overflow = drawer.classList.contains('open') ? 'hidden' : '';
    });
  }
</script>

<slot />

<div class="disclaimer-bar">
  <div class="container">⚠️ <strong>Disclaimer:</strong> Calculations are estimates for informational purposes only. Rates and costs vary by lender, credit score, and location. Consult a licensed mortgage professional before making financial decisions.</div>
</div>

<footer>
  <div class="ft-inner">
    <div>
      <div class="ft-logo">Mortgage<em>Calc</em></div>
      <div class="ft-tagline">Free mortgage calculators for US homebuyers · 2025</div>
      <!-- PRODUCT HUNT DRIVE SUPPORT BADGE (Uncomment when live on Product Hunt) -->
      <!--
      <div style="display: flex; align-items: center; margin-top: 15px;">
        <a href="https://www.producthunt.com/posts/mortgagecalc?embed=true&utm_source=badge-featured&utm_medium=badge&utm_souce=badge-mortgagecalc" target="_blank">
          <img src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=YOUR_POST_ID&theme=dark" alt="MortgageCalc - Free mortgage calculators | Product Hunt" style="width: 250px; height: 54px; display: block;" width="250" height="54" />
        </a>
      </div>
      -->
    </div>
    <div class="ft-col">
      <h4>Tools</h4>
      <a href="/">Mortgage Calculator</a>
      <a href="/affordability">Affordability Calculator</a>
      <a href="/refinance">Refinance Calculator</a>
    </div>
    <div class="ft-col">
      <h4>Top Guides</h4>
      <a href="/blog/how-mortgage-works">How a Mortgage Works</a>
      <a href="/blog/first-time-home-buyer-guide">First-Time Buyer Guide</a>
      <a href="/blog/pmi-explained">PMI Explained</a>
      <a href="/blog/mortgage-vs-rent">Buy vs Rent</a>
      <a href="/blog">All 15 Guides →</a>
    </div>
    <div class="ft-col">
      <h4>Company</h4>
      <a href="/about">About</a>
      <a href="/privacy">Privacy Policy</a>
    </div>
  </div>
  <div class="ft-copy">© 2025 mortgage.socialninjas.in · Free mortgage calculators · Not financial advice · <a href="/privacy" style="color:#475569;">Privacy</a></div>
</footer>
<style>
/* Responsive Mobile Drawer CSS */
.mobile-menu-btn {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink);
  padding: 4px;
  z-index: 1100;
  margin-left: 10px;
}
.mobile-menu-btn svg {
  width: 22px;
  height: 22px;
}
.mobile-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  padding: 100px 2rem 40px;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  overflow-y: auto;
}
.mobile-drawer.open {
  transform: translateX(0);
}
.drawer-links {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 2rem;
}
.drawer-link {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  text-decoration: none;
  color: var(--ink2);
  letter-spacing: -0.4px;
}
.drawer-link.active {
  color: var(--blue);
}
.drawer-promo-card {
  margin-top: auto;
  background: linear-gradient(135deg, #0f172a, #1e293b);
  border-radius: 18px;
  padding: 22px;
  color: #fff;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 10px 30px rgba(15,23,42,0.25);
}
.promo-title {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 6px;
  color: #5B9DF5;
}
.promo-text {
  font-size: 12.5px;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
  margin-bottom: 16px;
}
.promo-btn {
  display: block;
  background: linear-gradient(135deg, #1F4B99, #3b82f6);
  color: #fff !important;
  text-decoration: none;
  font-weight: 600;
  font-size: 13.5px;
  padding: 11px 18px;
  border-radius: 10px;
  text-align: center;
  box-shadow: 0 4px 16px rgba(37,99,235,0.3);
}

.mobile-menu-btn svg line {
  transform-origin: center;
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.mobile-menu-btn.active .line1 {
  transform: translateY(6px) rotate(45deg);
}
.mobile-menu-btn.active .line2 {
  opacity: 0;
}
.mobile-menu-btn.active .line3 {
  transform: translateY(-6px) rotate(-45deg);
}

@media(max-width: 768px) {
  .nav-links { display: none !important; }
  .mobile-menu-btn { display: block !important; }
}
</style>
<div class="toast" id="toast"></div>
</body>
</html>
