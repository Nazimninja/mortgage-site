---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
const h2s = headings.filter(h => h.depth === 2);
---
{h2s.length > 2 && (
  <div class="toc-wrap" id="toc">
    <div class="toc-label">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg>
      Table of contents
    </div>
    <ol class="toc-list">
      {h2s.map((h, i) => (
        <li>
          <a href={`#${h.slug}`} class="toc-link">
            <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
            <span>{h.text}</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
)}

<style>
.toc-wrap { background: var(--bluel); border: 1.5px solid rgba(29,78,216,0.15); border-radius: 14px; padding: 1.1rem 1.25rem; margin: 2rem 0; }
.toc-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--blue); margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
.toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
.toc-link { display: flex; align-items: baseline; gap: 8px; font-size: 13.5px; color: var(--ink2); text-decoration: none; padding: 4px 6px; border-radius: 6px; transition: all 0.14s; }
.toc-link:hover { background: rgba(29,78,216,0.08); color: var(--blue); }
.toc-num { font-family: var(--font-mono); font-size: 11px; color: var(--blue); font-weight: 600; flex-shrink: 0; }
</style>
